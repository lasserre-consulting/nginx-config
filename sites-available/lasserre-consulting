# Détection de la langue pour le site vitrine
map $http_accept_language $lang_redirect {
    default  "fr";
    ~*^en    "en";
    ~*^fr    "fr";
}

# ── Redirection HTTP → HTTPS ───────────────────────────────────────────────
server {
    listen 80;
    server_name lasserre-consulting.fr www.lasserre-consulting.fr;
    return 301 https://$host$request_uri;
}

# ── HTTPS ──────────────────────────────────────────────────────────────────
server {
    listen 443 ssl;
    server_name lasserre-consulting.fr www.lasserre-consulting.fr;

    ssl_certificate /etc/letsencrypt/live/lasserre-consulting.fr/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/lasserre-consulting.fr/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # ===== QUALIDOC =====
    location = /qualidoc {
        return 301 https://$host/qualidoc/;
    }

    location /qualidoc/ {
        root /var/www;
        try_files $uri $uri/ /qualidoc/index.html;
    }

    location /qualidoc/api/ {
        proxy_pass http://localhost:8082/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ===== CARNETROUTE =====
    location = /carnetroute {
        return 301 https://$host/carnetroute/;
    }

    location /carnetroute/ {
        root /var/www;
        try_files $uri $uri/ /carnetroute/index.html;
    }

    location /carnetroute/api/ {
        proxy_pass http://localhost:8080/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    location /ws/ {
        proxy_pass http://localhost:8080/ws/;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 86400s;
    }

    # ===== MISSION TRACKER =====
    location = /mission-tracker {
        return 301 https://$host/mission-tracker/;
    }

    location /mission-tracker/ {
        root /var/www;
        try_files $uri $uri/ /mission-tracker/index.html;
    }

    location /mission-tracker/api/ {
        proxy_pass http://localhost:8081/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ===== ENTREVIA =====
    location = /entrevia {
        return 301 https://$host/entrevia/;
    }

    location = /entrevia/api/stripe/webhook {
        limit_except POST { deny all; }
        proxy_pass http://127.0.0.1:3001;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 128k;
    }

    location /entrevia/api/auth/ {
        limit_req zone=entrevia_auth burst=10 nodelay;
        proxy_pass http://127.0.0.1:3001;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /entrevia/api/trpc/ {
        limit_req zone=entrevia_api burst=60 nodelay;
        proxy_pass http://127.0.0.1:3001;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location ~* ^/entrevia/_next/static/ {
        proxy_pass http://127.0.0.1:3001;
        add_header Cache-Control "public, max-age=31536000, immutable";
        proxy_set_header Host $host;
    }

    location /entrevia/ {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # ===== SITE VITRINE =====
    # Redirection racine selon la langue du navigateur
    location = / {
        return 302 https://$host/$lang_redirect/;
    }

    # Locale française
    location /fr/ {
        alias /var/www/lasserre-consulting-site/fr/;
        index index.html;
        add_header Cache-Control "no-store, no-cache, must-revalidate";
        try_files $uri $uri/ /fr/index.html;
    }

    # Locale anglaise
    location /en/ {
        alias /var/www/lasserre-consulting-site/en/;
        index index.html;
        add_header Cache-Control "no-store, no-cache, must-revalidate";
        try_files $uri $uri/ /en/index.html;
    }

    # Assets racine générés par Angular (manifest, favicon, etc.)
    location / {
        root /var/www/lasserre-consulting-site/fr;
        try_files $uri =404;
    }
}
